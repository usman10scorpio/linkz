# Copy this file to backend/.env and fill in the values

# MongoDB connection string
# For local development with the default port:
MONGODB_URI=mongodb://localhost:27017/linkz-seats

# JWT secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-secret

# Server port (optional, defaults to 4000)
PORT=4000

# Frontend origin for CORS (optional, defaults to http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173

# Log level (optional, defaults to "info")
LOG_LEVEL=info

# Node environment
NODE_ENV=development
